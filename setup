#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./setup [OPTIONS]

Options:
  --help      Show this help message and exit
  --dry-run   Print planned setup action and exit
EOF
}

if [[ ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

if [[ ${1:-} == "--dry-run" ]]; then
  echo "setup_status=not_implemented"
  echo "message=runtime setup will be implemented in a later Containerfile/Podman PR"
  exit 0
fi

if [[ $# -gt 0 ]]; then
  echo "error: unknown option: $1" >&2
  usage >&2
  exit 2
fi

echo "runtime setup is not implemented yet; this is a placeholder until a later Containerfile/Podman PR"
exit 0
