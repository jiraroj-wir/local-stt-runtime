#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
Usage: ./transcribe [OPTIONS] INPUT

Options:
  --help            Show this help message and exit.
  --list-presets    List available runtime presets and exit.
  --gpu             Force GPU mode.
  --cpu             Force CPU mode.
  --out DIR         Use DIR as the exact output directory.
  --dry-run         Print resolved values without running transcription.
USAGE
}

list_presets() {
  cat <<'PRESETS'
linux-gpu  Linux with NVIDIA CUDA runtime.
linux-cpu  Linux CPU runtime through Podman.
macos-cpu  macOS CPU runtime through Podman.
PRESETS
}

mode="auto"
out_dir=""
dry_run=false
input_file=""
image_name="local-stt-runtime"
cuda_check_image="nvidia/cuda:12.4.1-base-ubuntu22.04"

while (($# > 0)); do
  case "$1" in
    --help)
      usage
      exit 0
      ;;
    --list-presets)
      list_presets
      exit 0
      ;;
    --gpu)
      if [[ "$mode" == "cpu" ]]; then
        echo "Error: --gpu and --cpu cannot be used together." >&2
        exit 1
      fi
      mode="gpu"
      shift
      ;;
    --cpu)
      if [[ "$mode" == "gpu" ]]; then
        echo "Error: --gpu and --cpu cannot be used together." >&2
        exit 1
      fi
      mode="cpu"
      shift
      ;;
    --out)
      shift
      if (($# == 0)); then
        echo "Error: --out requires a directory argument." >&2
        exit 1
      fi
      out_dir="$1"
      shift
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    --*)
      echo "Error: unknown option: $1" >&2
      exit 1
      ;;
    *)
      if [[ -n "$input_file" ]]; then
        echo "Error: exactly one input file is required." >&2
        exit 1
      fi
      input_file="$1"
      shift
      ;;
  esac
done

if [[ -z "$input_file" ]]; then
  echo "Error: exactly one input file is required." >&2
  exit 1
fi

if [[ -z "$out_dir" ]]; then
  input_dir=$(dirname "$input_file")
  input_base=$(basename "$input_file")
  stem=${input_base%.*}
  if [[ "$input_dir" == "." ]]; then
    out_dir="$stem"
  else
    out_dir="$input_dir/$stem"
  fi
fi

planned_device="$mode"
if [[ "$mode" == "gpu" ]]; then
  planned_device="cuda"
fi

if [[ "$dry_run" == "true" ]]; then
  echo "input=$input_file"
  echo "output_dir=$out_dir"
  echo "mode=$mode"
  echo "selected_device=$planned_device"
  echo "podman_image=$image_name"
  exit 0
fi

if ! command -v podman >/dev/null 2>&1; then
  echo "Error: podman is required but was not found in PATH." >&2
  exit 1
fi

run_cuda_check() {
  podman run --rm \
    --device nvidia.com/gpu=all \
    --security-opt=label=disable \
    "$cuda_check_image" \
    nvidia-smi >/dev/null 2>&1
}

case "$mode" in
  cpu)
    device="cpu"
    ;;
  gpu)
    if run_cuda_check; then
      device="cuda"
    else
      echo "Error: CUDA/CDI GPU check failed; cannot continue with --gpu." >&2
      exit 1
    fi
    ;;
  auto)
    if run_cuda_check; then
      device="cuda"
    else
      echo "CUDA/CDI GPU check failed; falling back to CPU." >&2
      device="cpu"
    fi
    ;;
esac

if ! podman image exists "$image_name"; then
  "$script_dir/setup"
fi

cache_dir="$HOME/.cache/local-stt-runtime"
podman_args=(run --rm)
if [[ "$device" == "cuda" ]]; then
  podman_args+=(
    --device nvidia.com/gpu=all
    --security-opt=label=disable
  )
fi

podman_args+=(
  -v "$PWD:/work"
  -v "$cache_dir:/cache"
  "$image_name"
  -m app.transcribe
  "$input_file"
  --output-dir "$out_dir"
  --device "$device"
  --backend fake
)

podman "${podman_args[@]}"
